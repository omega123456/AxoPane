{
  "name": "axopane",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build --no-bundle",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cargo gm-test-integration",
    "test:rust:coverage": "node scripts/run-rust-coverage.mjs",
    "test:e2e": "node ./scripts/ensure-playwright-port.mjs && playwright test",
    "test:all": "pnpm test:coverage && pnpm test:rust:coverage && pnpm test:e2e",
    "clean:rust-target": "cargo clean --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "typecheck": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "release:tauri-version": "node scripts/bump-tauri-version.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-virtual": "^3.13.12",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-updater": "^2.9.1",
    "@visx/curve": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "lucide-react": "^0.553.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/vite": "^4.1.17",
    "@tauri-apps/cli": "^2.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "playwright": "^1.56.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.8"
  },
  "packageManager": "pnpm@10.30.2"
}
