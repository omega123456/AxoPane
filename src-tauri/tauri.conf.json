{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxoPane",
  "version": "0.1.0",
  "identifier": "com.axopane.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm exec vite dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm exec vite build"
  },
  "app": {
    "windows": [
      {
        "title": "AxoPane",
        "width": 1600,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 720,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/windows/Everything64.dll"]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY_BEFORE_SIGNED_RELEASE",
      "endpoints": ["https://github.com/OWNER/REPO/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
