{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AxoPane",
  "version": "1.23.4",
  "identifier": "com.axopane.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm exec vite dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm exec vite build"
  },
  "app": {
    "windows": [
      {
        "title": "AxoPane",
        "width": 1600,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 720,
        "decorations": true,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/windows/Everything64.dll"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlDQTgwOUEzQUY5RkQzMzAKUldRdzA1K3Zvd21vbkpVaFBhY2dTbjgvaHlsSWtuNzBzV1lZSTB6d20wdU14d2Y0US95aEZHbmIK",
      "endpoints": [
        "https://github.com/omega123456/AxoPane/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
